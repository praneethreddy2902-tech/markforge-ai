nematic fade (tall, multi-stop) */\n.vb{\n  position:absolute;bottom:0;left:0;right:0;\n  height:380px;\n  background:linear-gradient(\n    to top,\n    #0a0a0a  0%,\n    #0a0a0a  12%,\n    rgba(10,10,10,0.96) 30%,\n    rgba(10,10,10,0.78) 50%,\n    rgba(10,10,10,0.35) 70%,\n    transparent 100%\n  );\n  z-index:5;pointer-events:none;\n}\n\n/* ── ACCENT GLOW — sits behind headline ── */\n.glow{\n  position:absolute;\n  width:520px;height:520px;border-radius:50%;\n  background:radial-gradient(circle,#1166002a 0%,#1166000d 35%,transparent 65%);\n  bottom:80px;left:50%;transform:translateX(-50%);\n  z-index:6;pointer-events:none;\n}\n\n/* Corner accent */\n.corner{position:absolute;top:0;right:0;border-left:80px solid transparent;border-top:80px solid #1166002a;z-index:4}\n\n/* ── TOPBAR ── */\n.topbar{\n  position:absolute;top:0;left:0;right:0;\n  padding:22px 44px;\n  display:flex;align-items:center;justify-content:space-between;\n  z-index:9;\n}\n.logo-wrap{display:flex;align-items:center;gap:10px}\n.logo-img{\n  height:36px;width:auto;max-width:140px;\n  object-fit:contain;\n  background:rgba(255,255,255,0.93);\n  padding:5px 10px;border-radius:3px;\n}\n.logo-text{\n  font-family:'Barlow Condensed',sans-serif;font-weight:900;\n  font-size:30px;letter-spacing:0.07em;\n  color:#fff;text-transform:uppercase;\n  display:none\n}\n.badge{\n  font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;\n  letter-spacing:0.36em;text-transform:uppercase;\n  color:rgba(255,255,255,0.28);\n  border:1px solid rgba(255,255,255,0.07);\n  padding:5px 13px;\n}\n.abar{position:absolute;left:44px;top:76px;width:48px;height:3px;background:#116600;z-index:9}\n\n/* ── SIDE TEXT ── */\n.side{position:absolute;top:0;bottom:0;display:flex;align-items:center;z-index:8}\n.side span{\n  writing-mode:vertical-rl;\n  font-family:'Barlow Condensed',sans-serif;font-weight:700;\n  font-size:9px;letter-spacing:0.46em;text-transform:uppercase;\n  color:rgba(255,255,255,0.11);\n}\n.sl{left:12px}\n.sr{right:12px;transform:rotate(180deg)}\n\n/* ── HEADLINE ── */\n.hl{\n  position:absolute;\n  bottom:216px;\n  left:44px;right:44px;\n  z-index:8;\n}\n.eyebrow{\n  font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;\n  letter-spacing:0.45em;text-transform:uppercase;color:#116600;\n  margin-bottom:12px;\n  display:flex;align-items:center;gap:12px;\n}\n.eyebrow::after{content:'';flex:1;height:1px;background:linear-gradient(to right,#11660066,transparent)}\n.hed{\n  font-family:'Barlow Condensed',sans-serif;font-weight:900;\n  font-size:86px;line-height:0.87;\n  color:#fff;text-transform:uppercase;letter-spacing:-0.03em;\n  text-shadow:0 4px 40px rgba(0,0,0,0.6);\n}\n.hed .ha{\n  color:#116600;\n  font-style:italic;\n  display:block;\n}\n\n/* ── BOTTOM CONTENT ── */\n.bot{\n  position:absolute;bottom:0;left:0;right:0;\n  padding:0 44px 28px;\n  z-index:9;\n  background:linear-gradient(to top,#0a0a0a 0%,rgba(10,10,10,0.98) 55%,transparent 100%);\n}\n.rule{width:100%;height:1px;background:rgba(255,255,255,0.06);margin-bottom:14px}\n.tags{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap}\n.tag{\n  font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;\n  letter-spacing:0.16em;text-transform:uppercase;padding:5px 11px;\n}\n.ta{color:#116600;border:1px solid #11660055;background:#11660010}\n.to{color:rgba(255,255,255,0.35);border:1px solid rgba(255,255,255,0.1)}\n.brow{display:flex;align-items:center;justify-content:space-between}\n/* CTA — angled top-right corner for premium campaign feel */\n.cta{\n  font-family:'Barlow Condensed',sans-serif;font-weight:900;\n  font-size:13px;letter-spacing:0.26em;text-transform:uppercase;\n  color:#ffffff;background:#116600;\n  border:none;padding:13px 34px;\n  text-decoration:none;display:inline-block;cursor:pointer;\n  clip-path:polygon(0 0,calc(100% - 10px) 0,100% 10px,100% 100%,0 100%);\n}\n.wm{\n  font-family:'Barlow',sans-serif;font-size:7.5px;\n  letter-spacing:0.12em;color:rgba(255,255,255,0.07);text-transform:uppercase;\n}\n</style>\n</head>\n<body>\n<div class=\"poster\">\n\n  <!-- Ghost text -->\n  <div class=\"ghost\"><div class=\"gr\" style=\"top:2%;font-size:100px;opacity:0.04;\">FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS</div><div class=\"gr\" style=\"top:18%;font-size:118px;opacity:0.055;\">YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND</div><div class=\"gr\" style=\"top:36%;font-size:106px;opacity:0.038;filter:blur(1px);\">FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS</div><div class=\"gr\" style=\"top:54%;font-size:90px;opacity:0.028;filter:blur(2px);\">YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND</div><div class=\"gr\" style=\"top:70%;font-size:78px;opacity:0.018;filter:blur(3px);\">FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS  FIND  YOUR  GREATNESS</div></div>\n\n  <!-- Image grid (full bleed) -->\n  <div class=\"ig\">  <div class=\"gm\"></div>  <div class=\"gs\">    <div class=\"gt\"></div>    <div class=\"gt\"></div>  </div>  <div class=\"vl\"></div>  <div class=\"vr\"></div>  <div class=\"vt\"></div>  <div class=\"vb\"></div></div>\n\n  <!-- Glow + corner accent -->\n  <div class=\"glow\"></div>\n  <div class=\"corner\"></div>\n\n  <!-- Side text -->\n  <div class=\"side sl\"><span>NIKE, INC.</span></div>\n  <div class=\"side sr\"><span>ORIGINALS</span></div>\n\n  <!-- Top bar -->\n  <div class=\"topbar\">\n    <div class=\"logo-wrap\">\n      <img src=\"data:image/png;base64,\" alt=\"Nike, Inc.\" class=\"logo-img\" onerror=\"this.style.display='none';document.querySelector('.logo-text').style.display='block'\">\n      <div class=\"logo-text\">Nike, Inc.</div>\n    </div>\n    <div class=\"badge\">SS 202